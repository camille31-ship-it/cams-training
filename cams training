function todayISO(){return new Date().toISOString().slice(0,10)}
function formatDate(date){return new Date(date).toLocaleDateString("fr-FR")}
function cleanExerciseName(name){return String(name||"").replace(/^[\s\-–—•⁃🔵0-9.]+/g,"").replace(/[:：]+$/g,"").trim()}
function normalizeText(v){return String(v||"").toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[^a-z0-9]+/g,' ').trim()}
function detectSide(ex){
 const side=normalizeText(ex.side||"");
 if(side.includes("gauche"))return "gauche";
 if(side.includes("droite"))return "droite";
 if(side.includes("bilateral")||side.includes("deux cotes"))return "bilatéral";
 const txt=normalizeText(ex.name||"");
 if(/(^| )gauche( |$)|(^| )g( |$)/.test(txt))return "gauche";
 if(/(^| )droite( |$)|(^| )d( |$)/.test(txt))return "droite";
 if(txt.includes("bilateral")||txt.includes("deux cotes"))return "bilatéral";
 return "";
}
function baseExerciseName(ex){return normalizeText(ex.name).replace(/\b(gauche|droite|left|right|unilateral|unilaterale|d|g)\b/g,"").replace(/\s+/g," ').trim()||normalizeText(ex.name)}
function isSideOnlyName(name){
 const n=normalizeText(name);
 return /^(droite|gauche)( droite| gauche)?$/.test(n);
}
function inferExerciseParentsFromNote(note){
 const text=String(note||"");
 const parents=[];
 const push=(name)=>{if(!parents.includes(name))parents.push(name)};
 if(/leg\s*extension/i.test(text))push("Leg extension");
 if(/leg\s*curl/i.test(text))push("Leg curl");
 if(/presse\s*horizontale|leg\s*press/i.test(text))push("Presse horizontale");
 if(/mollet|calves/i.test(text))push("Mollets presse");
 if(/hip\s*thrust/i.test(text))push("Hip thrust");
 return parents;
}
function repairLegacySideOnlyExercises(session){
 const parents=inferExerciseParentsFromNote(session.note);
 let sideOnlyIndex=0;
 return (session.exercises||[]).map(ex=>{
  if(!isSideOnlyName(ex.name))return ex;
  const side=detectSide(ex)||((sideOnlyIndex%2===0)?"droite":"gauche");
  const parent=parents[Math.floor(sideOnlyIndex/2)]||parents[0]||"Exercice unilatéral à identifier";
  sideOnlyIndex++;
  return {
   ...ex,
   name:parent,
   muscle:ex.muscle&&ex.muscle!=="Autre"?ex.muscle:guessMuscleFromName(parent),
   side,
   rawName:ex.name,
   notes:[ex.notes,`Nom brut corrigé : ${ex.name}`].filter(Boolean).join(" • ")
  };
 });
}
function exerciseTonnage(ex){if(Number.isFinite(Number(ex.tonnageOverride)))return Math.round(Number(ex.tonnageOverride));return Math.round(Number(ex.weight||0)*Number(ex.reps||0)*Number(ex.sets||0))}
function ensureExerciseBaseline(ex){
 if(ex && ex.baseTonnage==null)ex.baseTonnage=exerciseTonnage(ex);
 return ex;
}
function tonnageDeltaHtml(ex){
 ensureExerciseBaseline(ex);
 const now=exerciseTonnage(ex);
 const base=Number(ex.baseTonnage||0);
 const delta=now-base;
 const cls=delta>0?'delta-pos':(delta<0?'delta-neg':'delta-zero');
 const sign=delta>0?'+':'';
 return `<div class="live-tonnage"><div class="muted">Tonnage</div><div class="big">${now} kg</div><div>Référence : ${base} kg • Variation : <span class="${cls}">${sign}${delta} kg</span></div></div>`;
}
function enrichExercisesWithBaseline(exercises){
 return (exercises||[]).map(ex=>ensureExerciseBaseline({...ex}));
}
function guessMuscleFromName(name){
 const t=normalizeText(name);
 if(t.includes('leg extension')||t.includes('presse')||t.includes('leg press')||t.includes('squat'))return 'Quadriceps';
 if(t.includes('leg curl'))return 'Ischios';
 if(t.includes('hip')||t.includes('fessier')||t.includes('abductor')||t.includes('adducteur'))return 'Fessiers';
 if(t.includes('mollet')||t.includes('calves'))return 'Mollets';
 if(t.includes('tirage')||t.includes('row')||t.includes('pull down')||t.includes('traction'))return 'Dos';
 if(t.includes('pec')||t.includes('convergente')||t.includes('developpe')||t.includes('fly')||t.includes('poulie'))return 'Pectoraux';
 if(t.includes('elevation')||t.includes('shoulder')||t.includes('epaule'))return 'Épaules';
 if(t.includes('biceps')||t.includes('curl'))return 'Biceps';
 if(t.includes('triceps'))return 'Triceps';
 if(t.includes('abdo')||t.includes('crunch')||t.includes('planche'))return 'Abdos';
 if(t.includes('lombaire'))return 'Lombaires';
 return 'Autre';
}
function parseExercisesFromNote(session){
 const note=String(session.note||''); if(!note)return [];
 const parts=note.split(/\||\n|🔵|⁃|•/).map(x=>x.trim()).filter(Boolean);
 const existing=(session.exercises||[]).map(e=>normalizeText(e.name));
 const found=[];
 for(const part of parts){
  const kgs=[...part.matchAll(/(?:avec|à|a|charge)\s*:?\s*(\d+(?:[.,]\d+)?)\s*kg/gi)];
  const series=[...part.matchAll(/(\d+)\s*[x×]\s*(\d+)/gi)];
  if(!series.length||kgs.length!==1)continue;
  const first=series[0].index;
  let name=cleanExerciseName(part.slice(0,first).replace(/[,:;]+$/,''));
  if(!name||name.length<3)continue;
  const norm=normalizeText(name);
  if(existing.some(e=>e&& (e.includes(norm)||norm.includes(e))))continue;
  const weight=Number(kgs[0][1].replace(',','.'));
  const totalReps=series.reduce((sum,m)=>sum+Number(m[1])*Number(m[2]),0);
  found.push({name,muscle:guessMuscleFromName(name),weight,reps:Number(series[0][2]),sets:Number(series[0][1]),done:true,fromNote:true,tonnageOverride:weight*totalReps,notes:'extrait de la note de séance'});
 }
 return found;
}
