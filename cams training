function refreshSavedLiveStats(i){
 if(editingSavedSessionIndex===null)return;
 const s=data.sessions[editingSavedSessionIndex];
 const ex=s?.exercises?.[i];
 if(!ex)return;
 const tonnage=document.getElementById(`saved-tonnage-${i}`);
 if(tonnage)tonnage.textContent=`${exerciseTonnage(ex)} kg`;
 const total=document.getElementById('saved-session-tonnage');
 if(total)total.textContent=`${sessionTonnage(s)} kg`;
}
function updateSavedSessionField(k,v){
 if(editingSavedSessionIndex===null)return;
 data.sessions[editingSavedSessionIndex][k]=v;
 saveData();
}
function updateSavedExercise(i,k,v){
 if(editingSavedSessionIndex===null)return;
 const ex=data.sessions[editingSavedSessionIndex].exercises[i];
 ex[k]=["weight","reps","sets"].includes(k)?(v===""?null:Number(v)):v;
 saveData();
 refreshSavedLiveStats(i);
}
function toggleSavedExerciseDone(i){
 if(editingSavedSessionIndex===null)return;
