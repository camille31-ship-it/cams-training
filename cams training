function renderTimelineChart(){
 const {months,totals}=getMonthlyMuscleTotals();
 if(months.length<2)return `<p class="muted">Pas encore assez de dates pour tracer une courbe.</p>`;
 const muscleSums=Object.entries(totals).map(([m,vals])=>[m,Object.values(vals).reduce((a,b)=>a+b,0)]).sort((a,b)=>b[1]-a[1]).slice(0,6);
 const selected=muscleSums.map(x=>x[0]);
 const width=Math.max(720,months.length*70), height=280, padL=54, padR=18, padT=20, padB=44;
 const max=Math.max(1,...selected.flatMap(m=>months.map(mon=>totals[m][mon]||0)));
 const colors=["#8fd3ff","#7c5cff","#6ee7b7","#ffd166","#ff7a90","#c084fc"];
 const x=(i)=>padL+(i/(Math.max(1,months.length-1)))*(width-padL-padR);
 const y=(v)=>padT+(1-v/max)*(height-padT-padB);
 let grid="";
 for(let g=0;g<=4;g++){const yy=padT+g*(height-padT-padB)/4;grid+=`<line class="chart-grid" x1="${padL}" y1="${yy}" x2="${width-padR}" y2="${yy}"></line>`;}
 const lines=selected.map((m,mi)=>{
  const pts=months.map((mon,i)=>`${x(i)},${y(totals[m][mon]||0)}`).join(" ");
  const dots=months.map((mon,i)=>`<circle cx="${x(i)}" cy="${y(totals[m][mon]||0)}" r="3.2" fill="${colors[mi%colors.length]}"><title>${m} • ${mon} • ${totals[m][mon]||0} kg</title></circle>`).join("");
  return `<polyline fill="none" stroke="${colors[mi%colors.length]}" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" points="${pts}"></polyline>${dots}`;
 }).join("");
 const labels=months.map((mon,i)=>`<text class="chart-label" x="${x(i)}" y="${height-16}" text-anchor="middle">${mon.slice(2)}</text>`).join("");
 const legend=selected.map((m,i)=>`<span class="legend-item"><span class="legend-dot" style="background:${colors[i%colors.length]}"></span>${m}</span>`).join("");
 return `<div class="chart-wrap"><svg class="chart-svg" viewBox="0 0 ${width} ${height}" preserveAspectRatio="none">
  ${grid}<line class="chart-axis" x1="${padL}" y1="${padT}" x2="${padL}" y2="${height-padB}"></line><line class="chart-axis" x1="${padL}" y1="${height-padB}" x2="${width-padR}" y2="${height-padB}"></line>
  <text class="chart-label" x="8" y="18">tonnage / mois</text>${labels}${lines}
 </svg></div><div class="legend">${legend}</div>`;
}
