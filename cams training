function isLegTrackingMuscle(m){return ['Quadriceps','Ischios','Fessiers','Mollets'].includes(m)}
function tonnageByMuscleBalanced(exercises){
 const totals={}, groups={};
 exercises.filter(ex=>ex.done!==false).forEach(ex=>{
  const muscle=ex.muscle||'Autre', vol=exerciseTonnage(ex), side=detectSide(ex);
  if(isLegTrackingMuscle(muscle)&&(side==='gauche'||side==='droite')){
   const key=muscle+'|'+baseExerciseName(ex); groups[key]=groups[key]||{muscle,left:0,right:0,other:0};
   if(side==='gauche')groups[key].left+=vol; else groups[key].right+=vol;
  }else totals[muscle]=(totals[muscle]||0)+vol;
 });
 Object.values(groups).forEach(g=>{const balanced=(g.left&&g.right)?((g.left+g.right)/2):(g.left||g.right);totals[g.muscle]=(totals[g.muscle]||0)+Math.round(balanced)});
 return totals;
}
