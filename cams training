function reportTimelineSvg(list){
 const months=[...new Set(list.map(s=>getMonthKey(s.date)).filter(Boolean))].sort();
 if(months.length<2)return '<p>Pas assez de dates pour générer une courbe.</p>';
 const totals={};
 list.forEach(s=>{
  const month=getMonthKey(s.date); if(!month)return;
  Object.entries(tonnageByMuscleBalanced(allSessionExercises(s))).forEach(([m,v])=>{
   if(!totals[m])totals[m]={}; totals[m][month]=(totals[m][month]||0)+v;
  });
 });
 const selected=Object.entries(totals).map(([m,vals])=>[m,Object.values(vals).reduce((a,b)=>a+b,0)]).sort((a,b)=>b[1]-a[1]).slice(0,5).map(x=>x[0]);
 if(!selected.length)return '<p>Aucune donnée musculaire exploitable.</p>';
 const width=760,height=260,padL=56,padR=22,padT=22,padB=44;
 const max=Math.max(1,...selected.flatMap(m=>months.map(mon=>totals[m][mon]||0)));
 const colors=['#1fd1bd','#0a7f86','#7c5cff','#ff9f1c','#ff4d6d'];
 const x=i=>padL+(i/(Math.max(1,months.length-1)))*(width-padL-padR);
 const y=v=>padT+(1-v/max)*(height-padT-padB);
 let grid='';
 for(let g=0;g<=4;g++){const yy=padT+g*(height-padT-padB)/4;grid+=`<line x1="${padL}" y1="${yy}" x2="${width-padR}" y2="${yy}" stroke="#e2e8f0"/>`;}
 const lines=selected.map((m,mi)=>{
  const pts=months.map((mon,i)=>`${x(i)},${y(totals[m][mon]||0)}`).join(' ');
  const dots=months.map((mon,i)=>`<circle cx="${x(i)}" cy="${y(totals[m][mon]||0)}" r="3" fill="${colors[mi%colors.length]}"/>`).join('');
  return `<polyline fill="none" stroke="${colors[mi%colors.length]}" stroke-width="3" points="${pts}"/>${dots}`;
 }).join('');
 const labels=months.map((mon,i)=>`<text x="${x(i)}" y="${height-16}" font-size="11" fill="#64748b" text-anchor="middle">${mon}</text>`).join('');
 const legend=selected.map((m,i)=>`<span style="display:inline-flex;align-items:center;gap:6px;margin-right:12px;font-size:12px;color:#334155"><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:${colors[i%colors.length]}"></span>${m}</span>`).join('');
 return `<div class="report-chart"><h2>Évolution dans le temps</h2><svg viewBox="0 0 ${width} ${height}" width="100%" height="260">${grid}<line x1="${padL}" y1="${padT}" x2="${padL}" y2="${height-padB}" stroke="#94a3b8"/><line x1="${padL}" y1="${height-padB}" x2="${width-padR}" y2="${height-padB}" stroke="#94a3b8"/><text x="8" y="18" font-size="11" fill="#64748b">tonnage/mois</text>${labels}${lines}</svg><div>${legend}</div></div>`;
}
function reportMuscleBarsSvg(totals){
 const entries=Object.entries(totals).sort((a,b)=>b[1]-a[1]).slice(0,10);
 if(!entries.length)return '<p>Aucune donnée musculaire.</p>';
 const width=760,row=26,padL=130,padR=28,height=entries.length*row+36;
 const max=Math.max(1,...entries.map(x=>x[1]));
 const colors=['#1fd1bd','#7c5cff','#6ee7b7','#ffd166','#ff7a90','#8fd3ff'];
 const bars=entries.map(([m,v],i)=>{
  const y=24+i*row; const w=Math.max(4,(v/max)*(width-padL-padR));
  return `<text x="0" y="${y+13}" font-size="12" fill="#334155">${m}</text><rect x="${padL}" y="${y}" width="${w}" height="16" rx="8" fill="${colors[i%colors.length]}"/><text x="${padL+w+8}" y="${y+13}" font-size="12" fill="#334155">${v} kg</text>`;
 }).join('');
 return `<div class="report-chart"><h2>Répartition par muscle</h2><svg viewBox="0 0 ${width} ${height}" width="100%" height="${height}">${bars}</svg></div>`;
}
function openReport(start,end){
 const list=data.sessions.filter(s=>s.date>=start&&s.date<=end);
 const totals={};
 list.forEach(s=>{
  Object.entries(tonnageByMuscleBalanced(allSessionExercises(s))).forEach(([m,v])=>{
   totals[m]=(totals[m]||0)+v;
  });
 });

 const total=list.reduce((a,s)=>a+sessionTonnage(s),0);
 const max=Math.max(1,...Object.values(totals));

 const muscleHtml=Object.entries(totals)
  .sort((a,b)=>b[1]-a[1])
  .map(([m,v])=>`
   <p><b>${m}</b> : ${v} kg</p>
   <div class="bar"><div class="fill" style="width:${Math.max(4,(v/max)*100)}%"></div></div>
  `).join("") || "<p>Aucune donnée musculaire sur cette période.</p>";

 const sessionsHtml=list.map(s=>`
  <div class="session">
   <h3>${formatDate(s.date)} — ${s.title||s.name}</h3>
   <p><b>Tonnage :</b> ${sessionTonnage(s)} kg</p>
   <p><b>Durée :</b> ${s.duration||"—"} min</p>
   <ul>${allSessionExercises(s).map(ex=>`<li><b>${ex.name}</b> — ${exerciseTonnage(ex)} kg${ex.weight!=null?` • ${ex.weight} kg`:""}${ex.sets!=null&&ex.reps!=null?` • ${ex.sets}×${ex.reps}`:""}${ex.side?` • ${ex.side}`:""}${ex.fromNote?` • note convertie`:""}</li>`).join("")}</ul>
   <p>${s.note||""}</p>
  </div>
 `).join("") || "<p>Aucune séance sur cette période.</p>";

 const w=window.open("","_blank");
 w.document.write(`
 <html>
 <head>
  <title>Rapport Cam's Training</title>
  <style>
   body{font-family:Arial,sans-serif;padding:28px;color:#111}
   h1{margin-bottom:4px}
   .meta{color:#555;margin-bottom:24px}
   .kpi{font-size:34px;font-weight:900;color:#0a7f86;margin:12px 0}
   .bar{height:12px;background:#e7eeee;border-radius:999px;margin:6px 0 16px;overflow:hidden}
   .fill{height:12px;background:linear-gradient(90deg,#1fd1bd,#0a7f86)}
   .session{border-top:1px solid #ddd;padding:12px 0}
   @media print{button{display:none}}
  .from-note{border-color:rgba(255,209,102,.35);background:rgba(255,209,102,.06)}

.edit-panel{border:1px solid rgba(255,255,255,.22);background:rgba(255,255,255,.10)}
.edit-actions{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:10px}
.edit-tag{display:inline-block;padding:5px 8px;border-radius:999px;background:rgba(255,209,102,.16);border:1px solid rgba(255,209,102,.32);color:#ffe6a3;font-size:12px;margin-left:6px}
</style>
 </head>
 <body>
  <h1>Rapport Cam's Training</h1>
  <div class="meta">${start} → ${end}</div>
  <div class="kpi">${total} kg</div>
  <p><b>${list.length}</b> séance(s) sur la période.</p>
  ${reportTimelineSvg(list)}
  ${reportMuscleBarsSvg(totals)}
  <h2>Détail par muscle</h2>
  ${muscleHtml}
  <h2>Séances</h2>
  ${sessionsHtml}
  <script>setTimeout(()=>window.print(),500)<\/script>
 </body>
 </html>`);
 w.document.close();
}
