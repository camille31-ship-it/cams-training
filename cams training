function normalizeProgramTemplateExercise(ex){
 return {...ex,weight:ex.weight===""?null:ex.weight,reps:ex.reps===""?null:ex.reps,sets:ex.sets===""?null:ex.sets};
}
function addMissingProgramTemplates(){
 if(!Array.isArray(data.templates))data.templates=[];
 const existing=new Set(data.templates.map(t=>String(t.name||"").trim().toLowerCase()));
 const toAdd=CAM_PROGRAM_TEMPLATES
  .filter(t=>!existing.has(t.name.trim().toLowerCase()))
  .map(t=>({...t,locked:false,exercises:t.exercises.map(normalizeProgramTemplateExercise)}));
