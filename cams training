<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Cam's Training V3.9</title>
<style>
:root{
  --bg:#07090f;
  --glass:rgba(255,255,255,.105);
  --glass2:rgba(255,255,255,.155);
  --border:rgba(255,255,255,.18);
  --text:#f7f9ff;
  --muted:#aab3c5;
  --accent:#8fd3ff;
  --accent2:#7c5cff;
  --blue:#8fd3ff;
  --green:#6ee7b7;
  --red:#ff7a90;
  --gold:#ffd166;
  --pink:#ff7a90;
  --glassOpacity:.14;
  --glassBlur:26px;
  --shadow:0 24px 70px rgba(0,0,0,.38);
}
*{box-sizing:border-box}
body{
  margin:0;min-height:100vh;font-family:-apple-system,BlinkMacSystemFont,"SF Pro Display","Segoe UI",Arial,sans-serif;
  color:var(--text);
  background:
  radial-gradient(circle at 12% -8%,rgba(143,211,255,.26),transparent 34%),
  radial-gradient(circle at 88% 4%,rgba(124,92,255,.24),transparent 28%),
  radial-gradient(circle at 50% 110%,rgba(110,231,183,.10),transparent 32%),
  linear-gradient(180deg,var(--bg),#03040a);padding-bottom:98px;
}
header{position:sticky;top:0;z-index:20;padding:22px 18px 10px;background:linear-gradient(180deg,rgba(7,9,15,.90),rgba(7,9,15,.52));backdrop-filter:blur(28px) saturate(140%);-webkit-backdrop-filter:blur(28px) saturate(140%)}
h1{margin:0;font-size:28px;letter-spacing:-.5px} h2{margin:0 0 10px;font-size:21px} h3{margin:0 0 8px;font-size:17px}
.sub,.muted{color:var(--muted)} .sub{font-size:13px;margin-top:4px}
main{padding:10px 14px;max-width:840px;margin:auto}
.card{background:linear-gradient(145deg,rgba(255,255,255,var(--glassOpacity)),rgba(255,255,255,calc(var(--glassOpacity) * .42)));border:1px solid var(--border);border-radius:26px;padding:16px;margin:12px 0;box-shadow:var(--shadow);backdrop-filter:blur(var(--glassBlur)) saturate(145%);-webkit-backdrop-filter:blur(var(--glassBlur)) saturate(145%)}
.card-strong{background:linear-gradient(135deg,rgba(143,211,255,.20),rgba(124,92,255,.12),rgba(255,255,255,.07))}
.exercise-card{background:rgba(255,255,255,.075);border:1px solid var(--border);border-radius:22px;padding:14px;margin:10px 0;backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px)}
.exercise-card.done{background:rgba(66,214,157,.10);border-color:rgba(66,214,157,.55)}
button{width:100%;border:1px solid var(--border);background:var(--glass2);color:var(--text);border-radius:17px;padding:13px;font-size:15px;font-weight:750}
button.primary{border:0;color:#050712;background:linear-gradient(135deg,var(--accent),var(--accent2));box-shadow:0 14px 32px rgba(124,92,255,.28)}
button.danger{color:#ffd6d6;border-color:rgba(255,107,107,.45)}
input,select,textarea{width:100%;margin:6px 0 10px;padding:12px;font-size:16px;color:var(--text);background:rgba(0,0,0,.30);border:1px solid var(--border);border-radius:15px}
textarea{min-height:76px} label{font-size:12px;color:var(--muted)}
.grid,.row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.kpi{font-size:34px;font-weight:900;color:var(--accent);letter-spacing:-1px}
.pill{display:inline-block;padding:6px 9px;border:1px solid var(--border);border-radius:999px;color:var(--muted);font-size:12px;margin:3px}
.line{display:flex;justify-content:space-between;gap:12px;padding:9px 0;border-bottom:1px solid rgba(255,255,255,.08);font-size:14px}
.bar{height:10px;background:rgba(255,255,255,.09);border-radius:999px;overflow:hidden;margin:6px 0 12px}
.bar>div{height:100%;background:linear-gradient(90deg,var(--accent),var(--blue))}
.hidden{display:none!important}
.nav{position:fixed;left:10px;right:10px;bottom:10px;z-index:30;display:grid;grid-template-columns:repeat(5,1fr);gap:6px;padding:8px;border:1px solid var(--border);border-radius:26px;background:rgba(7,9,15,.72);box-shadow:0 18px 60px rgba(0,0,0,.44);backdrop-filter:blur(30px) saturate(150%);-webkit-backdrop-filter:blur(30px) saturate(150%)}
.nav button{padding:10px 3px;font-size:11px;border-radius:16px;background:transparent}
.nav button.active{background:rgba(31,209,189,.18);color:var(--accent)}
.report{background:white;color:#111;padding:24px}

summary{cursor:pointer;list-style:none}
summary::-webkit-details-marker{display:none}
.template-summary{display:flex;align-items:center;justify-content:space-between;gap:12px}
.chevron{font-size:18px;color:var(--accent);transition:transform .18s ease}
details[open] .chevron{transform:rotate(90deg)}
.visual-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.visual-tile{padding:12px;border-radius:20px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.13)}
.muscle-dot{width:11px;height:11px;border-radius:999px;background:linear-gradient(135deg,var(--accent),var(--accent2));display:inline-block;margin-right:7px}
.dictionary-card h3{display:flex;align-items:center;gap:8px}

.metric{display:inline-flex;align-items:center;gap:6px;padding:7px 10px;border-radius:999px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);font-size:12px;color:var(--muted);margin:3px 4px 3px 0}
.metric b{color:var(--text)}
.metric-tonnage{background:linear-gradient(135deg,rgba(255,209,102,.18),rgba(255,122,144,.12));border-color:rgba(255,209,102,.25)}
.metric-muscle{background:linear-gradient(135deg,rgba(143,211,255,.16),rgba(124,92,255,.10));border-color:rgba(143,211,255,.22)}
.mini-tonnage{margin-top:7px;color:var(--gold);font-size:13px;font-weight:800}
.ex-detail{margin-top:8px;display:flex;flex-wrap:wrap;gap:6px}
.muscle-section{overflow:hidden}
.muscle-section summary{padding:2px 0}
.exercise-clean-row{padding:10px 0;border-top:1px solid rgba(255,255,255,.08)}
.exercise-clean-row:first-child{border-top:0}
.exercise-clean-row b{display:block;margin-bottom:4px}
.color-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
input[type="color"]{height:46px;padding:4px}
.range-line{display:grid;grid-template-columns:1fr 76px;gap:10px;align-items:center}
.report-mode{padding:12px;border:1px solid rgba(255,255,255,.12);border-radius:18px;background:rgba(255,255,255,.055);margin:10px 0}
.report-mode input[type="radio"]{width:auto;margin-right:8px}
.progress-card{background:linear-gradient(145deg,rgba(143,211,255,.16),rgba(124,92,255,.08),rgba(255,255,255,.055))}
.stat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.stat-box{border:1px solid rgba(255,255,255,.12);border-radius:20px;padding:12px;background:rgba(255,255,255,.07)}
.stat-box .value{font-size:22px;font-weight:900;color:var(--accent)}
@media(max-width:520px){.stat-grid{grid-template-columns:1fr}.color-row{grid-template-columns:1fr}}

@media(max-width:520px){.visual-grid{grid-template-columns:1fr 1fr}}

.chart-wrap{width:100%;overflow:auto;padding:8px 0}
.chart-svg{min-width:720px;width:100%;height:280px;display:block}
.chart-axis{stroke:rgba(255,255,255,.22);stroke-width:1}
.chart-grid{stroke:rgba(255,255,255,.08);stroke-width:1}
.chart-label{fill:var(--muted);font-size:11px}
.legend{display:flex;flex-wrap:wrap;gap:8px;margin-top:10px}
.legend-item{display:flex;align-items:center;gap:6px;color:var(--muted);font-size:12px}
.legend-dot{width:10px;height:10px;border-radius:999px;background:var(--accent)}
.history-ex-list{margin-top:12px}
.history-ex{padding:10px 0;border-top:1px solid rgba(255,255,255,.08)}
.history-ex-title{display:flex;justify-content:space-between;gap:12px;align-items:flex-start}
.meta-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
@media(max-width:520px){.meta-grid{grid-template-columns:1fr}}

.live-tonnage{margin-top:10px;padding:11px;border-radius:18px;background:linear-gradient(135deg,rgba(255,209,102,.16),rgba(143,211,255,.10));border:1px solid rgba(255,209,102,.22)}
.live-tonnage .big{font-size:20px;font-weight:900;color:var(--gold)}
.delta-pos{color:var(--green);font-weight:900}
.delta-neg{color:var(--red);font-weight:900}
.delta-zero{color:var(--muted);font-weight:900}
.report-chart{margin:18px 0 24px;padding:14px;border:1px solid #ddd;border-radius:18px;background:#fafafa}
@media(max-width:520px){.grid,.row{grid-template-columns:1fr}h1{font-size:25px}.kpi{font-size:30px}}
.from-note{border-color:rgba(255,209,102,.35);background:rgba(255,209,102,.06)}

.edit-panel{border:1px solid rgba(255,255,255,.22);background:rgba(255,255,255,.10)}
.edit-actions{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:10px}
.edit-tag{display:inline-block;padding:5px 8px;border-radius:999px;background:rgba(255,209,102,.16);border:1px solid rgba(255,209,102,.32);color:#ffe6a3;font-size:12px;margin-left:6px}
</style>
</head>
